# ==========================================
# GymDash Backend Environment Variables
# ==========================================
# Copy this file to .env or configure these variables in your deployment environment.

# ------------------------------------------
# Database Configuration
# ------------------------------------------
# Connection URL for MySQL (e.g., jdbc:mysql://hostname:port/dbname?sslMode=REQUIRED)
DB_URL=
# Database Username
DB_USERNAME=
# Database Password
DB_PASSWORD=

# ------------------------------------------
# Server Configuration
# ------------------------------------------
# The port the backend server will run on (Default: 8080)
PORT=8080

# ------------------------------------------
# CORS / WebAuthn Configuration
# ------------------------------------------
# The allowed origin for CORS and WebAuthn (e.g., https://your-frontend-domain.com)
ALLOWED_ORIGIN=http://localhost:5173

# ------------------------------------------
# Razorpay Configuration
# ------------------------------------------
# Your Razorpay API Key ID
RAZORPAY_KEY_ID=
# Your Razorpay API Key Secret
RAZORPAY_KEY_SECRET=

# ------------------------------------------
# Security (JWT) Configuration
# ------------------------------------------
# A strong, secret string used to sign JWT tokens (at least 256 bits for HS256)
JWT_SECRET=
